class Solution {
    static ArrayList<Integer> subarraySum(int[] arr, int target) {
        ArrayList<Integer> ls=new ArrayList<>();
    
       for(int i=0;i<arr.length;i++){
              int sum=0;
           for(int j=i;j<arr.length;j++){
               sum+=arr[j];
               if(sum==target){
                   ls.add(i+1);
                   ls.add(j+1);
                  return ls;
               }
               
           }
       }
       ls.add(-1);
       return ls;
    }
}
